# Trading venue (optional — read-only market fetch)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./.secret/kalshi.pem

# Polymarket (read-only URLs; trading also needs key + funder below)
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_PRIVATE_KEY_PATH=./.secret/polymarket.key
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_CONTROLLER_ADDRESS=
# API-only; do not deposit funds here
POLYMARKET_BUILDER_API_ADDRESS=
POLYMARKET_BUILDER_CODE=
# Relayer (gasless transactions; Settings → API Keys on polymarket.com)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_CHAIN_ID=137
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
PMXT_API_KEY=
PMXT_BASE_URL=
PMXT_AUTO_START_SERVER=

# Storage (`vercel env pull .env.local` for Vercel-managed values)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
MONGODB_URI=
MOTHERDUCK_TOKEN=
MOTHERDUCK_READONLY_TOKEN=
MOTHERDUCK_DATABASE=

# Herbie NWP cache
HERBIE_SAVE_DIR=./data/raw/herbie
HERBIE_CONFIG_PATH=./data/interim/herbie/config.toml

# Paths
DATA_DIR=./data
MODELS_DIR=./models

# NWS API
NWS_USER_AGENT=weather-trader (you@example.com)

# Vercel MongoDB test endpoint (optional)
MONGO_TEST_TOKEN=
